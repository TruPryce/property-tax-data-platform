{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-run-summary.schema.json",
  "title": "CountyForge Generic Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_contract_version", "request_contract_version", "run_id", "mode", "profile_id",
    "profile_version", "profile_sha256", "execution_eligible", "outcome", "disposition",
    "exit_code", "error_code", "started_at", "finished_at", "duration_seconds",
    "effective_budgets", "budget_usage", "result_schema", "artifacts"
  ],
  "properties": {
    "summary_contract_version": {"const": 1},
    "request_contract_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["review", "plan", "implement", "fix", "validate"]},
    "profile_id": {"type": "string"},
    "profile_version": {"type": "integer", "minimum": 1},
    "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "execution_eligible": {"type": "boolean"},
    "outcome": {"enum": ["succeeded", "failed", "not_executed"]},
    "disposition": {"enum": ["completed", "adapter_failed", "timed_out", "budget_exceeded", "profile_not_implemented", "validation_failed"]},
    "exit_code": {"type": "integer", "minimum": 0},
    "error_code": {"type": ["string", "null"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "duration_seconds": {"type": "number", "minimum": 0},
    "effective_budgets": {"$ref": "#/$defs/effectiveBudgets"},
    "budget_usage": {"$ref": "#/$defs/budgetUsage"},
    "result_schema": {"type": "string"},
    "artifacts": {
      "type": "object",
      "propertyNames": {"pattern": "^[A-Za-z0-9._-]+$"},
      "additionalProperties": {"type": "boolean"}
    }
  },
  "$defs": {
    "usageValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "value"],
          "properties": {
            "state": {"const": "reported"},
            "value": {"type": "number", "minimum": 0}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "value"],
          "properties": {
            "state": {"const": "unavailable"},
            "value": {"type": "null"}
          }
        }
      ]
    },
    "effectiveBudgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_clock_seconds", "attempts", "max_output_bytes", "max_input_bytes",
        "max_tokens", "max_cost_usd"
      ],
      "properties": {
        "wall_clock_seconds": {"type": "integer", "minimum": 1},
        "attempts": {"type": "integer", "minimum": 1},
        "max_output_bytes": {"type": "integer", "minimum": 1},
        "max_input_bytes": {"type": "integer", "minimum": 1},
        "max_tokens": {"type": ["integer", "null"], "minimum": 1},
        "max_cost_usd": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "budgetUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_clock_seconds", "attempts", "input_bytes", "output_bytes", "tokens", "cost_usd"],
      "properties": {
        "wall_clock_seconds": {"type": "number", "minimum": 0},
        "attempts": {"type": "integer", "minimum": 0},
        "input_bytes": {"type": "integer", "minimum": 0},
        "output_bytes": {"type": "integer", "minimum": 0},
        "tokens": {"$ref": "#/$defs/usageValue"},
        "cost_usd": {"$ref": "#/$defs/usageValue"}
      }
    }
  }
}
