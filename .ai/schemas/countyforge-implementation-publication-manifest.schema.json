{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-publication-manifest.schema.json","type":"object","additionalProperties":false,"required":["contract_version","run_id","issue_number","change_name","revision","base_sha","branch","commit_sha","draft_pr_number","validation_report_sha256"],"properties":{"contract_version":{"const":1},"run_id":{"type":"string","maxLength":128},"issue_number":{"type":"integer","minimum":1},"change_name":{"type":"string","pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$"},"revision":{"type":"integer","minimum":1},"base_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"branch":{"type":"string","pattern":"^countyforge/implement/issue-[0-9]+-[a-z0-9]+(?:-[a-z0-9]+)*-r[0-9]+$"},"commit_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"draft_pr_number":{"type":"integer","minimum":1},"validation_report_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}
