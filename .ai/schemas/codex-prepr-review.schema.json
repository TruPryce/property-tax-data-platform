            "description": "Finding severity; must be BLOCKER in this array."
          },
          "title": {
            "type": "string"
          },
          "file": {
            "type": [
              "string",
              "null"
            ],
            "description": "Repository-relative file path when known; null for repo-wide findings."
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "description": "1-based line number when known; null otherwise."
