{
  "description": "Structured output for the property-tax Codex pre-PR review. Kept within the JSON Schema subset accepted by Codex structured outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "summary",
    "blockers",
    "must_fix",
    "nice_to_fix",
    "questions",
    "recommended_next_action"
