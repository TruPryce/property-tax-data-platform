{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-command-event.schema.json","type":"object","additionalProperties":false,"required":["contract_version","run_id","command_id","phase","started_at","finished_at","exit_code","stdout_sha256","stderr_sha256","truncated","network_policy","workspace_revision"],"properties":{"contract_version":{"const":1},"run_id":{"type":"string","maxLength":128},"command_id":{"type":"string","pattern":"^[a-z][a-z0-9._-]+$"},"phase":{"enum":["inspect","task","validate"]},"started_at":{"type":"string","format":"date-time"},"finished_at":{"type":"string","format":"date-time"},"exit_code":{"type":["integer","null"],"minimum":0,"maximum":255},"stdout_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"stderr_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"truncated":{"type":"boolean"},"network_policy":{"enum":["disabled","registry_allowlist"]},"workspace_revision":{"type":"string","maxLength":128}}}
