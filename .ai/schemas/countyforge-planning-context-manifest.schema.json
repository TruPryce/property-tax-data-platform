{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-planning-context-manifest.schema.json",
  "title": "CountyForge Planning Context Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "run_id", "repository_full_name", "issue_number", "target_sha", "packet_sha256", "sources"],
  "properties": {
    "contract_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "repository_full_name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "issue_number": {"type": "integer", "minimum": 1},
    "target_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "packet_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sources": {"type": "array", "maxItems": 128, "items": {"type": "object", "additionalProperties": false, "required": ["source_id", "path", "category", "sha256", "bytes", "truncated"], "properties": {"source_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]{1,96}$"}, "path": {"type": "string", "maxLength": 240}, "category": {"type": "string", "maxLength": 64}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "bytes": {"type": "integer", "minimum": 0}, "truncated": {"type": "boolean"}}}}
  }
}
