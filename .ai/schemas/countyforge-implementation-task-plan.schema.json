{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-task-plan.schema.json", "type": "object", "additionalProperties": false,
  "required": ["contract_version", "run_id", "change_name", "tasks"],
  "properties": {"contract_version": {"const": 1}, "run_id": {"type": "string", "maxLength": 128}, "change_name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "tasks": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "object", "additionalProperties": false, "required": ["task_id", "description", "allowed_paths", "required_checks", "prerequisites", "risk", "status"], "properties": {"task_id": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}, "description": {"type": "string", "maxLength": 1024}, "allowed_paths": {"type": "array", "maxItems": 64, "items": {"type": "string"}}, "required_checks": {"type": "array", "maxItems": 32, "items": {"type": "string"}}, "prerequisites": {"type": "array", "maxItems": 32, "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}}, "risk": {"enum": ["normal", "higher_risk"]}, "status": {"const": "incomplete"}}}}}
}
