{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-result.schema.json",
  "title": "CountyForge Implementation Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "tasks_attempted", "tasks_completed", "changed_paths", "checks_run", "deviations", "remaining_work", "publication_eligibility"],
  "properties": {
    "status": {"enum": ["completed", "partial", "blocked", "profile_not_implemented"]},
    "tasks_attempted": {"$ref": "#/$defs/strings"},
    "tasks_completed": {"$ref": "#/$defs/strings"},
    "changed_paths": {"$ref": "#/$defs/strings"},
    "checks_run": {"$ref": "#/$defs/strings"},
    "deviations": {"$ref": "#/$defs/strings"},
    "remaining_work": {"$ref": "#/$defs/strings"},
    "publication_eligibility": {"enum": ["eligible", "ineligible", "not_evaluated"]}
  },
  "$defs": {"strings": {"type": "array", "items": {"type": "string"}}}
}
