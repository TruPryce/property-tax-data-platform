{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-packet.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["contract_version", "repository", "issue", "change", "trusted_base_sha", "run_id", "implementation_revision", "eligibility", "sources", "tasks", "policies", "non_goals"],
  "properties": {
    "contract_version": {"const": 1},
    "repository": {"type": "object", "additionalProperties": false, "required": ["id", "full_name"], "properties": {"id": {"type": "integer", "minimum": 1}, "full_name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"}}},
    "issue": {"type": "object", "additionalProperties": false, "required": ["number", "title", "body"], "properties": {"number": {"type": "integer", "minimum": 1}, "title": {"type": "string", "maxLength": 1024}, "body": {"type": "string", "maxLength": 20000}}},
    "change": {"type": "object", "additionalProperties": false, "required": ["name", "sha256", "files"], "properties": {"name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "files": {"type": "array", "minItems": 4, "maxItems": 32, "items": {"type": "string", "pattern": "^openspec/changes/[a-z0-9]+(?:-[a-z0-9]+)*/.*$"}}}},
    "trusted_base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"}, "implementation_revision": {"type": "integer", "minimum": 1},
    "eligibility": {"type": "object", "additionalProperties": false, "required": ["contract_version", "eligible", "repository", "issue_number", "change_name", "change_sha256", "trusted_base_sha", "planning_pr_merged", "approval_actor_id", "approval_actor_type", "blocking_reasons"], "properties": {"contract_version": {"const": 1}, "eligible": {"type": "boolean"}, "repository": {"type": "string"}, "issue_number": {"type": "integer", "minimum": 1}, "change_name": {"type": "string"}, "change_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "trusted_base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "planning_pr_merged": {"type": "boolean"}, "planning_pr_number": {"type": ["integer", "null"], "minimum": 1}, "planning_pr_merge_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}, "approval_actor_id": {"type": ["integer", "null"]}, "approval_actor_type": {"enum": ["User", null]}, "approval_actor_login": {"type": ["string", "null"], "maxLength": 128}, "approval_permission": {"enum": ["admin", "maintain", "write", null]}, "blocking_reasons": {"type": "array", "maxItems": 16, "items": {"type": "string"}}}},
    "sources": {"type": "array", "maxItems": 128, "items": {"type": "object", "additionalProperties": false, "required": ["source_id", "path", "sha256", "category", "bytes", "truncated", "selection_reason", "trust_class", "content"], "properties": {"source_id": {"type": "string", "pattern": "^[0-9a-f]{24}$"}, "path": {"type": "string", "maxLength": 512}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "category": {"type": "string"}, "bytes": {"type": "integer", "minimum": 0}, "truncated": {"type": "boolean"}, "selection_reason": {"type": "string"}, "trust_class": {"enum": ["trusted_contract", "untrusted_evidence"]}, "content": {"type": "string", "maxLength": 50000}}}},
    "tasks": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "object", "additionalProperties": false, "required": ["task_id", "description", "status", "allowed_paths", "required_checks", "risk"], "properties": {"task_id": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"}, "description": {"type": "string", "maxLength": 1024}, "status": {"enum": ["incomplete", "blocked"]}, "allowed_paths": {"type": "array", "maxItems": 64, "items": {"type": "string"}}, "required_checks": {"type": "array", "maxItems": 32, "items": {"type": "string"}}, "risk": {"enum": ["normal", "higher_risk"]}}}},
    "policies": {"type": "object", "additionalProperties": false, "required": ["path_policy", "network", "command_registry"], "properties": {"path_policy": {"const": "countyforge-implementation-paths.v1"}, "network": {"enum": ["disabled", "provider_only"]}, "command_registry": {"const": "countyforge-implementation-commands.v1"}}}, "non_goals": {"type": "array", "maxItems": 32, "items": {"type": "string"}}
  }
}
