{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-command-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "policy_id", "version", "default_network", "commands"],
  "properties": {
    "contract_version": {"const": 1},
    "policy_id": {"const": "countyforge-implementation-commands"},
    "version": {"const": 1},
    "default_network": {"const": "disabled"},
    "commands": {
      "type": "array", "minItems": 1, "maxItems": 32,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "executable", "arguments", "phase", "network", "workspace_mutating", "timeout_seconds", "max_output_bytes", "environment", "artifact_paths"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]+$"},
          "executable": {"type": "string", "pattern": "^[a-zA-Z0-9._/-]+$"},
          "arguments": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 128}},
          "phase": {"enum": ["inspect", "task", "validate"]},
          "network": {"enum": ["disabled", "registry_allowlist"]},
          "workspace_mutating": {"type": "boolean"},
          "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
          "max_output_bytes": {"type": "integer", "minimum": 1, "maximum": 1048576},
          "environment": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"}},
          "artifact_paths": {"type": "array", "maxItems": 32, "items": {"type": "string", "maxLength": 512}}
        }
      }
    }
  }
}
