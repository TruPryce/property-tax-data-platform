{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulse-ops-ai.github.io/platform-edge/schemas/codex-runner-event.schema.json",
  "title": "CodexRunnerEvent",
  "description": "Normalized per-run observability event for a dockerized Codex/Fugu pre-PR review run, written as a single NDJSON line at .ai/reviews/codex-prepr/<safe-branch>/<run-id>/codex-runner-event.ndjson. Derived only from non-secret provenance/summary values; never contains raw review content, stdout/stderr, model event payloads, API keys, Bitwarden tokens, or environment dumps. This schema validates ONE event object, not the NDJSON file. Local export only — see docs/engineering/codex-runner-observability.md; this does not deploy any live collector.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_contract_version",
    "event_type",
    "repo",
    "run_id",
    "branch",
    "safe_branch",
    "review_mode",
    "run_dir",
    "started_at",
    "finished_at",
    "duration_seconds",
    "status",
    "exit_code",
    "stage",
    "verdict",
    "secret_leak_detected",
    "packet_bytes",
    "packet_sha256",
    "max_packet_bytes",
    "schema_sha256",
    "head_sha",
    "head_short_sha",
    "review_base",
    "image",
    "image_id",
    "codex_cli_version",
    "model",
    "model_source",
    "model_provider",
    "reasoning_effort",
    "reasoning_effort_source",
    "sandbox",
    "web_search",
    "disabled_tools",
    "output_schema_sha256"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1, "description": "Version of this event schema." },
    "artifact_contract_version": { "type": ["integer", "null"], "description": "Per-run artifact contract version (run.summary.json et al.)." },
    "event_type": { "type": "string", "const": "codex_prepr_review_run" },
    "repo": { "type": ["string", "null"], "description": "Low-cardinality repository identifier (repo-root basename)." },
    "run_id": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "safe_branch": { "type": ["string", "null"], "description": "Branch name with characters outside [A-Za-z0-9._-] replaced by __." },
    "review_mode": { "type": ["string", "null"], "description": "How the runner executed (e.g. docker)." },
    "run_dir": { "type": ["string", "null"], "description": "Absolute source-of-truth run directory." },
    "started_at": { "type": ["string", "null"], "description": "UTC ISO-8601 start time." },
    "finished_at": { "type": ["string", "null"], "description": "UTC ISO-8601 finish time." },
    "duration_seconds": { "type": ["integer", "null"], "minimum": 0 },
    "status": { "type": ["string", "null"], "description": "succeeded | failed." },
    "exit_code": { "type": ["integer", "null"] },
    "stage": { "type": ["string", "null"], "description": "preflight | docker_run | review_missing | secret_leak_scan | observability_export | completed." },
    "verdict": { "type": ["string", "null"], "description": "pass | pass_with_notes | block, or null." },
    "secret_leak_detected": { "type": "boolean" },
    "packet_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "packet_sha256": { "type": ["string", "null"] },
    "max_packet_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "schema_sha256": { "type": ["string", "null"] },
    "head_sha": { "type": ["string", "null"] },
    "head_short_sha": { "type": ["string", "null"] },
    "review_base": { "type": ["string", "null"] },
    "image": { "type": ["string", "null"] },
    "image_id": { "type": ["string", "null"] },
    "codex_cli_version": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "model_source": { "type": ["string", "null"], "description": "override | image-default." },
    "model_provider": { "type": ["string", "null"] },
    "reasoning_effort": { "type": ["string", "null"], "description": "high | xhigh (normalized; max maps to xhigh)." },
    "reasoning_effort_source": { "type": ["string", "null"], "description": "override | image-default." },
    "sandbox": { "type": ["string", "null"], "description": "Codex sandbox posture (constant: danger-full-access, bounded by the container)." },
    "web_search": { "type": "boolean" },
    "disabled_tools": { "type": "array", "items": { "type": "string" }, "description": "Model-invokable tools disabled at the CLI." },
    "output_schema_sha256": { "type": ["string", "null"] }
  }
}
