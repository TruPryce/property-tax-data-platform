{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://github.com/TruPryce/property-tax-data-platform/.ai/schemas/countyforge-implementation-revision.schema.json","type":"object","additionalProperties":false,"required":["contract_version","revision","change_name","accepted_change_sha256","base_sha","predecessor_run_id","predecessor_pr_number","supersession_reason"],"properties":{"contract_version":{"const":1},"revision":{"type":"integer","minimum":1},"change_name":{"type":"string","pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$"},"accepted_change_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"base_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"predecessor_run_id":{"type":["string","null"],"maxLength":128},"predecessor_pr_number":{"type":["integer","null"],"minimum":1},"supersession_reason":{"type":"string","maxLength":256}}}
